<?xml version="1.0" encoding="utf-8"?>
<!--
  Paths exposed by the FileProvider in AndroidManifest.
  Only paths declared here can be shared via FileProvider.getUriForFile.
  Each <path> is relative to a well-known root:

    external-cache-path = Context.getExternalCacheDir()
    cache-path          = Context.getCacheDir()
    files-path          = Context.getFilesDir()

  bug_reports/ subdir holds attachment bundles assembled by BugReportUtils.
-->
<paths>
    <external-cache-path name="bug_reports" path="bug_reports/" />
    <cache-path          name="cache"       path="."            />
    <files-path          name="files"       path="."            />
</paths>
