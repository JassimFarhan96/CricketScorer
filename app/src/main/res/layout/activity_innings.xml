<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/c_bg_page">

    <!-- ═══════════ SCOREBOARD HEADER ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/green_dark">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="10dp">
            <TextView android:id="@+id/tv_innings_title"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="1st Innings"
                android:textColor="#FFFFFF" android:textSize="12sp" android:alpha="0.85"/>
            <Button android:id="@+id/btn_edit_overs"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✎ Edit overs"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_mode_badge"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:layout_marginEnd="6dp"
                android:minHeight="0dp" android:minWidth="0dp"
                android:visibility="gone"/>
            <TextView android:id="@+id/tv_mode_badge"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Two bat" android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_mode_badge"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingBottom="14dp" android:paddingTop="2dp">
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_score"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0/0" android:textColor="#FFFFFF"
                    android:textSize="34sp" android:fontFamily="sans-serif-medium"/>
                <TextView android:id="@+id/tv_overs_info"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ov 0.0 / 20" android:textColor="#AADECE" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:id="@+id/tv_crr"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CRR: 0.00" android:textColor="#AADECE" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_rrr"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RRR: -" android:textColor="#AADECE"
                    android:textSize="12sp" android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════ TARGET BANNER ═══════════ -->
    <LinearLayout android:id="@+id/layout_target_banner"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/amber_dark"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:visibility="gone">
        <TextView android:id="@+id/tv_target_info"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Target: -"
            android:textColor="#FFFFFF" android:textSize="13sp"
            android:fontFamily="sans-serif-medium"/>
        <TextView android:id="@+id/tv_required_balls"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="" android:textColor="#F5C475" android:textSize="12sp"/>
    </LinearLayout>

    <!-- ═══════════ BATTING PANEL — weight 3, scrollable ═══════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="@color/c_bg_card">
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BATTING" android:textSize="11sp"
                android:textColor="@color/c_text_secondary"
                android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp" android:layout_marginBottom="4dp"/>
            <TableLayout android:id="@+id/table_batsmen"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:stretchColumns="0" android:shrinkColumns="0"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- ═══════════ OVER TRACKER — weight 7 ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7"
        android:orientation="vertical"
        android:background="@color/c_scoreboard_section_bg"
        android:elevation="4dp">

        <!-- Current over: label + bowler + ball circles + buttons -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="8dp" android:paddingBottom="2dp">
            <TextView android:id="@+id/tv_current_over_label"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Over 1"
                android:textSize="12sp" android:fontFamily="sans-serif-medium"
                android:textColor="@color/c_text_primary"
                android:textAllCaps="true" android:letterSpacing="0.06"/>
            <TextView android:id="@+id/tv_balls_remaining"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="6 balls left"
                android:textSize="12sp" android:textColor="@color/c_text_secondary"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_current_bowler"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Bowling: -" android:textSize="11sp"
            android:textColor="@color/green_mid" android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp" android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_current_over_balls"
            android:layout_width="match_parent" android:layout_height="54dp"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:clipToPadding="false" android:overScrollMode="never"/>

        <com.google.android.flexbox.FlexboxLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:paddingStart="10dp" android:paddingEnd="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            app:flexWrap="wrap" app:justifyContent="flex_start"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <Button android:id="@+id/btn_dot" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Dot" android:textSize="13sp" android:textColor="@color/c_btn_default_fg"
                android:background="@drawable/bg_ball_btn_default"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_1" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="1" android:textSize="13sp" android:textColor="@color/c_btn_default_fg"
                android:background="@drawable/bg_ball_btn_default"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_2" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="2" android:textSize="13sp" android:textColor="@color/c_btn_default_fg"
                android:background="@drawable/bg_ball_btn_default"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_3" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="3" android:textSize="13sp" android:textColor="@color/c_btn_default_fg"
                android:background="@drawable/bg_ball_btn_default"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_4" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="4" android:textSize="13sp" android:textColor="@color/c_ball_four_fg"
                android:background="@drawable/bg_ball_btn_four"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_6" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="6" android:textSize="13sp" android:textColor="@color/c_ball_six_fg"
                android:background="@drawable/bg_ball_btn_six"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_wide" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Wide" android:textSize="13sp" android:textColor="@color/c_ball_wide_fg"
                android:background="@drawable/bg_ball_btn_wide"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_noball" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="No Ball" android:textSize="13sp" android:textColor="@color/c_ball_noball_fg"
                android:background="@drawable/bg_ball_btn_noball"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_wicket" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Wicket" android:textSize="13sp" android:textColor="@color/c_ball_wicket_fg"
                android:background="@drawable/bg_ball_btn_wicket"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            <Button android:id="@+id/btn_retired_hurt" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Ret. Hurt" android:textSize="12sp"
                android:textColor="@color/amber_dark"
                android:background="@drawable/bg_ball_btn_retired"
                android:layout_margin="3dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <!-- Baby Over button — only visible after ball 3, hidden by Java -->
            <Button android:id="@+id/btn_baby_over" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Baby Over" android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_ball_btn_babyover"
                android:layout_margin="3dp" android:paddingStart="10dp" android:paddingEnd="10dp"
                android:visibility="gone"/>
            <Button android:id="@+id/btn_undo" style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="&#x21A9; Undo" android:textSize="13sp"
                android:textColor="@color/c_text_secondary"
                android:background="@drawable/bg_ball_btn_undo"
                android:layout_margin="3dp" android:paddingStart="12dp" android:paddingEnd="12dp"/>
        </com.google.android.flexbox.FlexboxLayout>

        <!-- ══ HISTORY + BOWLING side by side, both independently scrollable ══
             Remaining vertical space split: history 60% | bowling 40%
             Each column has its own label + scrollable content.
        ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- LEFT: Over history (ball circles per over) — 60% width -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="OVER HISTORY"
                    android:textSize="10sp" android:textColor="@color/c_text_secondary"
                    android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="4dp" android:layout_marginBottom="2dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_over_history"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:overScrollMode="always"
                    android:clipToPadding="false"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="0.5dp"
                android:layout_height="match_parent"
                android:background="@color/c_divider"/>

            <!-- RIGHT: Bowling summary (overs per bowler) — 40% width -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BOWLING"
                    android:textSize="10sp" android:textColor="@color/c_text_secondary"
                    android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="4dp" android:layout_marginBottom="2dp"/>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:overScrollMode="always">

                    <TextView android:id="@+id/tv_bowler_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.7"
                        android:textColor="@color/c_text_primary"
                        android:paddingStart="10dp" android:paddingEnd="6dp"
                        android:paddingTop="2dp" android:paddingBottom="8dp"/>
                </ScrollView>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>
