<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/c_bg_page" android:fillViewport="true">

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/green_dark"
        android:padding="24dp" android:paddingTop="40dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Tournament setup" android:textColor="#AADECE" android:textSize="13sp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Configure your tournament" android:textColor="#FFFFFF"
          android:textSize="22sp" android:fontFamily="sans-serif-medium" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Players per team -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PLAYERS PER TEAM" android:textSize="11sp"
        android:textColor="@color/c_text_secondary" android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp" android:layout_marginTop="24dp" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/et_players_per_team"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="2 – 12 players"
        android:inputType="number"
        android:maxLength="2"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

    <!-- Number of teams -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NUMBER OF TEAMS" android:textSize="11sp"
        android:textColor="@color/c_text_secondary" android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp" android:layout_marginTop="20dp" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/et_number_of_teams"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Minimum 2 — type to add team name fields"
        android:inputType="number"
        android:maxLength="3"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

    <!-- Dynamic team name fields (horizontal scroll) -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TEAM NAMES" android:textSize="11sp"
        android:textColor="@color/c_text_secondary" android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp" android:layout_marginTop="20dp" android:layout_marginBottom="6dp"/>
    <HorizontalScrollView android:id="@+id/team_fields_scroll"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp">
      <LinearLayout android:id="@+id/team_fields_container"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:orientation="horizontal"/>
    </HorizontalScrollView>

    <Button android:id="@+id/btn_continue"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:text="Continue &#8594;" android:textSize="17sp"
        android:fontFamily="sans-serif-medium" android:textColor="#FFFFFF"
        android:backgroundTint="@color/green_dark"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginTop="32dp" android:layout_marginBottom="32dp"/>

  </LinearLayout>
</ScrollView>
