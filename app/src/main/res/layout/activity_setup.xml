<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/c_bg_page">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HOME TEAM" android:textSize="11sp" android:textColor="@color/c_text_secondary"
            android:letterSpacing="0.08" android:layout_marginBottom="5dp"/>
        <EditText android:id="@+id/et_home_team" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. Mumbai" android:maxLength="20" android:inputType="textCapWords"
            android:background="@drawable/bg_input_field" android:padding="12dp" android:textSize="14sp"
            android:textColor="@color/c_text_primary" android:textColorHint="@color/c_text_hint"/>
      </LinearLayout>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="VS" android:textSize="12sp" android:fontFamily="sans-serif-medium"
          android:textColor="@color/c_text_secondary" android:background="@drawable/bg_vs_badge"
          android:padding="8dp" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:layout_marginTop="18dp"/>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AWAY TEAM" android:textSize="11sp" android:textColor="@color/c_text_secondary"
            android:letterSpacing="0.08" android:layout_marginBottom="5dp"/>
        <EditText android:id="@+id/et_away_team" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. Delhi" android:maxLength="20" android:inputType="textCapWords"
            android:background="@drawable/bg_input_field" android:padding="12dp" android:textSize="14sp"
            android:textColor="@color/c_text_primary" android:textColorHint="@color/c_text_hint"/>
      </LinearLayout>
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NUMBER OF OVERS" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:letterSpacing="0.08" android:layout_marginBottom="5dp"/>
    <EditText android:id="@+id/et_overs" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Enter overs (1 - 50)" android:inputType="number" android:maxLength="2"
        android:background="@drawable/bg_input_field" android:padding="12dp" android:textSize="14sp"
        android:textColor="@color/c_text_primary" android:textColorHint="@color/c_text_hint" android:layout_marginBottom="14dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="TOSS" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:letterSpacing="0.08" android:layout_marginBottom="5dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="6dp">

      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Toss winner" android:textSize="10sp"
            android:textColor="@color/c_text_secondary" android:layout_marginBottom="2dp"/>
        <Spinner android:id="@+id/spinner_toss_winner"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:popupBackground="@color/c_bg_spinner_popup"/>
      </LinearLayout>

      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
          android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="6dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Chose to" android:textSize="10sp"
            android:textColor="@color/c_text_secondary" android:layout_marginBottom="2dp"/>
        <Spinner android:id="@+id/spinner_toss_choice"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:popupBackground="@color/c_bg_spinner_popup"/>
      </LinearLayout>

    </LinearLayout>

    <TextView android:id="@+id/tv_toss_summary"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textSize="12sp"
        android:textColor="@color/green_mid" android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="20dp"/>
    <TextView android:id="@+id/tv_label_home_players"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="HOME TEAM PLAYERS" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
    <LinearLayout android:id="@+id/container_home_players" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="20dp"/>
    <TextView android:id="@+id/tv_label_away_players"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="AWAY TEAM PLAYERS" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
    <LinearLayout android:id="@+id/container_away_players" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btn_start_match" android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Start Match" android:textSize="16sp" android:fontFamily="sans-serif-medium"
        android:textColor="#FFFFFF" android:backgroundTint="@color/green_dark" android:layout_marginBottom="24dp"/>
  </LinearLayout>
</ScrollView>