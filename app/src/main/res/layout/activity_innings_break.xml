<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/c_bg_page"
    android:fillViewport="true">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/green_dark"
        android:padding="20dp" android:paddingTop="36dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Innings Complete" android:textColor="#FFFFFF"
          android:textSize="20sp" android:fontFamily="sans-serif-medium"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="1st innings over" android:textColor="#AADECE"
          android:textSize="13sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- ── Score summary card ─────────────────────────────────── -->
    <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp" app:cardElevation="2dp"
        app:cardBackgroundColor="@color/c_bg_card">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="24dp" android:gravity="center">
        <TextView android:id="@+id/tv_batting_team"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Team A" android:textSize="14sp"
            android:textColor="@color/c_text_secondary"/>
        <TextView android:id="@+id/tv_first_innings_score"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="0/0" android:textSize="48sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/green_mid" android:layout_marginTop="4dp"/>
        <TextView android:id="@+id/tv_overs_played"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="in 0.0 overs" android:textSize="14sp"
            android:textColor="@color/c_text_secondary"/>
        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/c_divider"
            android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>
        <TextView android:id="@+id/tv_chasing_team"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Team B needs:" android:textSize="13sp"
            android:textColor="@color/c_text_secondary"/>
        <TextView android:id="@+id/tv_target"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="- runs" android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/amber_mid" android:layout_marginTop="6dp"/>
        <TextView android:id="@+id/tv_required_rr"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Required run rate: -" android:textSize="13sp"
            android:textColor="@color/c_text_secondary" android:layout_marginTop="6dp"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── 1st innings statistics section label ───────────────── -->
    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="1ST INNINGS STATISTICS"
        android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
        android:layout_marginStart="20dp" android:layout_marginBottom="8dp"/>

    <!-- ── Three tappable stat cards ─────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp">

      <!-- Run Rate Graph card -->
      <LinearLayout android:id="@+id/card_run_rate"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:background="@drawable/bg_stat_card_clickable"
          android:padding="16dp" android:layout_marginBottom="8dp"
          android:clickable="true" android:focusable="true">
        <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:background="@drawable/bg_menu_icon_green">
          <ImageView android:layout_width="26dp" android:layout_height="26dp"
              android:src="@drawable/ic_statistics"
              android:contentDescription="Run rate graph"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="14dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Run Rate Progression" android:textSize="15sp"
              android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Over-by-over run rate chart" android:textSize="12sp"
              android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
      </LinearLayout>

      <!-- Batting stats card -->
      <LinearLayout android:id="@+id/card_batting_stats"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:background="@drawable/bg_stat_card_clickable"
          android:padding="16dp" android:layout_marginBottom="8dp"
          android:clickable="true" android:focusable="true">
        <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:background="@drawable/bg_menu_icon_amber">
          <ImageView android:layout_width="26dp" android:layout_height="26dp"
              android:src="@drawable/ic_single_batsman"
              android:contentDescription="Batting stats"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="14dp">
          <TextView android:id="@+id/tv_batting_card_title"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="1st Innings — Batting" android:textSize="15sp"
              android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Batsman scores, fours, sixes, SR" android:textSize="12sp"
              android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
      </LinearLayout>

      <!-- Bowling stats card -->
      <LinearLayout android:id="@+id/card_bowling_stats"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:gravity="center_vertical"
          android:background="@drawable/bg_stat_card_clickable"
          android:padding="16dp" android:layout_marginBottom="16dp"
          android:clickable="true" android:focusable="true">
        <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:background="@drawable/bg_menu_icon_blue">
          <ImageView android:layout_width="26dp" android:layout_height="26dp"
              android:src="@drawable/ic_cricket_bat"
              android:contentDescription="Bowling stats"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:layout_marginStart="14dp">
          <TextView android:id="@+id/tv_bowling_card_title"
              android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="1st Innings — Bowling" android:textSize="15sp"
              android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="Bowler overs, runs, wickets, economy" android:textSize="12sp"
              android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
      </LinearLayout>

    </LinearLayout>

    <!-- Spacer to push button to bottom when content is short -->
    <View android:layout_width="match_parent" android:layout_height="16dp"/>

    <!-- ── Start 2nd Innings button ───────────────────────────── -->
    <Button android:id="@+id/btn_start_2nd_innings"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Start 2nd Innings  &#8594;" android:textSize="16sp"
        android:fontFamily="sans-serif-medium" android:textColor="#FFFFFF"
        android:backgroundTint="@color/green_dark"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"/>

  </LinearLayout>
</ScrollView>
