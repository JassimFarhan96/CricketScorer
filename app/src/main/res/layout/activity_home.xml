<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml
    Home screen layout. Contains:
      - Cricket ball hero image + title (dark green header)
      - Three menu cards: Track Match, Recent Matches, Statistics
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F0F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero header ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#085041"
            android:padding="32dp"
            android:gravity="center">

            <!-- Cricket ball (circle drawable) -->
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_cricket_ball"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cricket Scorer"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Track live match scores, overs &amp; stats"
                android:textColor="#AADECE"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ── Menu card ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Track new match -->
                <LinearLayout
                    android:id="@+id/layout_track_match"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="🏏"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/bg_menu_icon_green" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Track new match"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#111111" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Set up teams and overs"
                            android:textSize="12sp"
                            android:textColor="#888780"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#BBBBBB" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#E0E0E0" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Recent matches -->
                <LinearLayout
                    android:id="@+id/layout_recent_matches"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="📋"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/bg_menu_icon_amber" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recent matches"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#111111" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View past scorecards"
                            android:textSize="12sp"
                            android:textColor="#888780"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="#BBBBBB" />
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="#E0E0E0" android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

                <!-- Statistics -->
                <LinearLayout
                    android:id="@+id/layout_statistics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="📊"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/bg_menu_icon_blue" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Match statistics"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#111111" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Full scorecard &amp; analysis"
                            android:textSize="12sp"
                            android:textColor="#888780"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="22sp" android:textColor="#BBBBBB" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
