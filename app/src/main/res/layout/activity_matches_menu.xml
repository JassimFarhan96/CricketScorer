<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/c_bg_page" android:fillViewport="true">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/green_dark"
        android:padding="24dp" android:paddingTop="40dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="🏏 Matches" android:textColor="#FFFFFF"
          android:textSize="22sp" android:fontFamily="sans-serif-medium"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Track, view and analyse individual matches"
          android:textColor="#AADECE" android:textSize="13sp" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_margin="16dp"
        app:cardCornerRadius="16dp" app:cardElevation="2dp"
        app:cardBackgroundColor="@color/c_bg_card">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical">

        <!-- Track new match -->
        <LinearLayout android:id="@+id/layout_track_match"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:background="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true">
          <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
              android:gravity="center" android:background="@drawable/bg_menu_icon_green">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#127951;" android:textSize="20sp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Track new match" android:textSize="15sp"
                android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Set up teams and overs" android:textSize="12sp"
                android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/c_divider"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

        <!-- Recent matches -->
        <LinearLayout android:id="@+id/layout_recent_matches"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:background="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true">
          <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
              android:gravity="center" android:background="@drawable/bg_menu_icon_amber">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#9201;" android:textSize="20sp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Recent matches" android:textSize="15sp"
                android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="View past scorecards" android:textSize="12sp"
                android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/c_divider"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"/>

        <!-- Match statistics -->
        <LinearLayout android:id="@+id/layout_statistics"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="14dp" android:background="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true">
          <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
              android:gravity="center" android:background="@drawable/bg_menu_icon_blue">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&#128202;" android:textSize="20sp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Match statistics" android:textSize="15sp"
                android:fontFamily="sans-serif-medium" android:textColor="@color/c_text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Full scorecard &amp; analysis" android:textSize="12sp"
                android:textColor="@color/c_text_secondary" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="&#8250;" android:textSize="22sp" android:textColor="@color/c_text_hint"/>
        </LinearLayout>

      </LinearLayout>
    </androidx.cardview.widget.CardView>
  </LinearLayout>
</ScrollView>
