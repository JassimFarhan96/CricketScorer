<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/c_bg_page">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:background="@color/green_dark" android:padding="20dp" android:paddingTop="36dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Match Statistics" android:textColor="#FFFFFF" android:textSize="20sp" android:fontFamily="sans-serif-medium"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Select a saved match to view full scorecard"
        android:textColor="#AADECE" android:textSize="12sp" android:layout_marginTop="2dp"/>
  </LinearLayout>
  <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
      <TextView android:id="@+id/tv_empty" android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="No saved matches found.
Finish a match and tap Save Match."
          android:textSize="14sp" android:textColor="@color/c_text_secondary"
          android:gravity="center" android:padding="48dp" android:visibility="gone"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="SELECT MATCH" android:textSize="11sp" android:textColor="@color/c_text_secondary"
          android:letterSpacing="0.08" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
      <Spinner android:id="@+id/spinner_matches" android:layout_width="match_parent" android:layout_height="52dp"
          android:background="@drawable/bg_input_field" android:paddingStart="12dp" android:paddingEnd="12dp"
          android:popupBackground="@color/c_bg_spinner_popup" android:layout_marginBottom="20dp"/>
      <LinearLayout android:id="@+id/layout_preview" android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:background="@drawable/bg_match_card"
          android:padding="18dp" android:layout_marginBottom="20dp" android:visibility="gone">
        <TextView android:id="@+id/tv_preview_teams" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Team A vs Team B" android:textSize="17sp" android:textColor="@color/green_mid" android:fontFamily="sans-serif-medium"/>
        <TextView android:id="@+id/tv_preview_result" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Result" android:textSize="13sp" android:textColor="@color/c_text_primary" android:layout_marginTop="6dp"/>
        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/c_divider" android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
        <TextView android:id="@+id/tv_preview_scores" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Scores" android:textSize="13sp" android:textColor="@color/c_text_primary" android:lineSpacingMultiplier="1.4"/>
        <TextView android:id="@+id/tv_preview_date" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Date" android:textSize="11sp" android:textColor="@color/c_text_hint" android:layout_marginTop="10dp"/>
      </LinearLayout>
      <Button android:id="@+id/btn_view_stats" android:layout_width="match_parent" android:layout_height="52dp"
          android:text="View Full Statistics" android:textSize="16sp" android:fontFamily="sans-serif-medium"
          android:textColor="#FFFFFF" android:backgroundTint="@color/green_dark" android:visibility="gone"/>
    </LinearLayout>
  </ScrollView>
</LinearLayout>