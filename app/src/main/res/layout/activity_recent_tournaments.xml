<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/c_bg_page" android:orientation="vertical">

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:background="@color/green_dark"
      android:padding="24dp" android:paddingTop="40dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🏆 Recent Tournaments" android:textColor="#FFFFFF"
        android:textSize="22sp" android:fontFamily="sans-serif-medium"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Saved tournaments — 5 per page"
        android:textColor="#AADECE" android:textSize="13sp" android:layout_marginTop="4dp"/>
  </LinearLayout>

  <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
      android:layout_weight="1">
    <LinearLayout android:id="@+id/list_container"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginTop="8dp"/>
  </ScrollView>

  <TextView android:id="@+id/tv_empty"
      android:layout_width="match_parent" android:layout_height="wrap_content"
      android:text="No saved tournaments yet"
      android:textSize="14sp" android:gravity="center" android:padding="24dp"
      android:textColor="@color/c_text_secondary"
      android:visibility="gone"/>

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:gravity="center_vertical"
      android:padding="12dp" android:background="@color/c_bg_card">
    <Button android:id="@+id/btn_prev"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="◀ Prev" android:layout_marginEnd="8dp"/>
    <TextView android:id="@+id/tv_page_indicator"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:gravity="center"
        android:textSize="13sp" android:textColor="@color/c_text_primary"/>
    <Button android:id="@+id/btn_next"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Next ▶" android:layout_marginStart="8dp"/>
  </LinearLayout>
</LinearLayout>
