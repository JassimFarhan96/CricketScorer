<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/c_bg_page" android:fillViewport="true">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@color/green_dark"
        android:padding="24dp" android:paddingTop="40dp">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Team setup" android:textColor="#AADECE" android:textSize="13sp" android:layout_marginBottom="4dp"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Configure your match" android:textColor="#FFFFFF"
          android:textSize="22sp" android:fontFamily="sans-serif-medium"/>
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:text="Same settings apply to both teams" android:textColor="#AADECE"
          android:textSize="13sp" android:layout_marginTop="6dp"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="PLAYERS PER TEAM" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"
        android:layout_marginStart="20dp" android:layout_marginTop="24dp" android:layout_marginBottom="10dp"/>

    <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        app:cardCornerRadius="16dp" app:cardElevation="2dp" app:cardBackgroundColor="@color/c_bg_card">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="24dp" android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#127951;" android:textSize="32sp" android:layout_marginBottom="16dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
          <ImageButton android:id="@+id/btn_minus" android:layout_width="52dp" android:layout_height="52dp"
              android:background="@drawable/bg_counter_btn" android:src="@drawable/ic_minus"
              android:scaleType="center" android:contentDescription="Decrease"/>
          <TextView android:id="@+id/tv_player_count" android:layout_width="110dp" android:layout_height="wrap_content"
              android:text="11" android:textSize="64sp" android:fontFamily="sans-serif-medium"
              android:textColor="@color/green_mid" android:gravity="center" android:includeFontPadding="false"/>
          <ImageButton android:id="@+id/btn_plus" android:layout_width="52dp" android:layout_height="52dp"
              android:background="@drawable/bg_counter_btn" android:src="@drawable/ic_plus"
              android:scaleType="center" android:contentDescription="Increase"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_count_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="players per team" android:textSize="14sp"
            android:textColor="@color/c_text_secondary" android:layout_marginTop="6dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Choose between 2 and 11" android:textSize="12sp"
            android:textColor="@color/c_text_hint" android:layout_marginTop="10dp"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="BATTING MODE" android:textSize="11sp" android:textColor="@color/c_text_secondary"
        android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"
        android:layout_marginStart="20dp" android:layout_marginTop="24dp" android:layout_marginBottom="10dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginStart="16dp" android:layout_marginEnd="16dp">
      <LinearLayout android:id="@+id/card_mode_single" android:layout_width="0dp"
          android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"
          android:gravity="center" android:padding="16dp" android:layout_marginEnd="6dp"
          android:background="@drawable/bg_mode_card_default" android:clickable="true" android:focusable="true">
        <TextView android:id="@+id/tv_single_check" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#10003;" android:textSize="14sp" android:textColor="@color/c_mode_card_selected_border"
            android:fontFamily="sans-serif-medium" android:layout_gravity="end" android:visibility="invisible"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#129516;" android:textSize="36sp" android:gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Single" android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/c_text_primary" android:gravity="center" android:layout_marginTop="10dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Striker only" android:textSize="12sp" android:textColor="@color/c_text_secondary"
            android:gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No strike rotation" android:textSize="11sp" android:textColor="@color/c_text_hint"
            android:gravity="center" android:layout_marginTop="2dp"/>
      </LinearLayout>
      <LinearLayout android:id="@+id/card_mode_two" android:layout_width="0dp"
          android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"
          android:gravity="center" android:padding="16dp" android:layout_marginStart="6dp"
          android:background="@drawable/bg_mode_card_selected" android:clickable="true" android:focusable="true">
        <TextView android:id="@+id/tv_two_check" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#10003;" android:textSize="14sp" android:textColor="@color/c_mode_card_selected_border"
            android:fontFamily="sans-serif-medium" android:layout_gravity="end" android:visibility="visible"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#129516;&#129516;" android:textSize="36sp" android:gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Two" android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/c_text_primary" android:gravity="center" android:layout_marginTop="10dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Striker + Non-striker" android:textSize="12sp" android:textColor="@color/c_text_secondary"
            android:gravity="center" android:layout_marginTop="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Strike rotates on odd runs" android:textSize="11sp" android:textColor="@color/c_text_hint"
            android:gravity="center" android:layout_marginTop="2dp"/>
      </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="32dp"/>
    <Button android:id="@+id/btn_continue" android:layout_width="match_parent" android:layout_height="56dp"
        android:text="Continue &#8594;" android:textSize="17sp" android:fontFamily="sans-serif-medium"
        android:textColor="#FFFFFF" android:backgroundTint="@color/green_dark"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="32dp"/>
  </LinearLayout>
</ScrollView>