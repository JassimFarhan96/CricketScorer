<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Winner banner ──────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_winner_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#085041"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="28sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_winner_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_winner_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#AADECE"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ── SAVE MATCH BUTTON (hidden after save / when viewing from disk) -->
        <Button
            android:id="@+id/btn_save_match"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💾  Save Match"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFF"
            android:backgroundTint="#085041"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="14dp"
            android:visibility="visible" />

        <!-- ── Summary cards ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView android:id="@+id/tv_team1_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Team A" android:textSize="11sp" android:textColor="#888780"
                    android:textAllCaps="true" android:letterSpacing="0.06" />

                <TextView android:id="@+id/tv_team1_score"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0/0" android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" android:textColor="#111111"
                    android:layout_marginTop="4dp" />

                <TextView android:id="@+id/tv_team1_crr"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.0 ov" android:textSize="11sp" android:textColor="#888780"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView android:id="@+id/tv_team2_name"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Team B" android:textSize="11sp" android:textColor="#888780"
                    android:textAllCaps="true" android:letterSpacing="0.06" />

                <TextView android:id="@+id/tv_team2_score"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0/0" android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" android:textColor="#111111"
                    android:layout_marginTop="4dp" />

                <TextView android:id="@+id/tv_team2_crr"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.0 ov" android:textSize="11sp" android:textColor="#888780"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── 1st Innings batting table ─────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="1ST INNINGS — BATTING"
            android:textSize="11sp" android:textColor="#888780"
            android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp" android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="1dp">
            <TableLayout android:id="@+id/table_first_innings"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:stretchColumns="0" android:shrinkColumns="0" android:padding="4dp" />
        </androidx.cardview.widget.CardView>

        <!-- ── 2nd Innings batting table ─────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="2ND INNINGS — BATTING"
            android:textSize="11sp" android:textColor="#888780"
            android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp" android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="1dp">
            <TableLayout android:id="@+id/table_second_innings"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:stretchColumns="0" android:shrinkColumns="0" android:padding="4dp" />
        </androidx.cardview.widget.CardView>

        <!-- ── Share section ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SHARE SCORECARD"
            android:textSize="11sp" android:textColor="#888780"
            android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp" android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp">

            <EditText
                android:id="@+id/et_whatsapp_number"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:hint="+91 9876543210" android:inputType="phone"
                android:background="@drawable/bg_input_field"
                android:padding="12dp" android:textSize="15sp"
                android:textColor="#111111" android:textColorHint="#999999"
                android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btn_share_whatsapp"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Share on WhatsApp" android:textSize="15sp"
                android:fontFamily="sans-serif-medium" android:textColor="#FFFFFF"
                android:backgroundTint="#25D366" android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btn_share_general"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Share via other apps..."
                android:textSize="14sp" android:textColor="#085041"
                android:background="@drawable/bg_btn_outline"
                android:layout_marginBottom="8dp" />

            <Button android:id="@+id/btn_new_match"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Start new match" android:textSize="14sp"
                android:textColor="#888780"
                android:background="@drawable/bg_ball_btn_default"
                android:layout_marginBottom="24dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
